{
  "forceJpg": true,
  "jpegQuality": 90,
  "paths": {
    "inputDir": "./raw_images",
    "outputDir": "./final_posts"
  },
  "title": "封面標題文字",
  "align": "center",
  "fontFamily": [
    "PingFang TC",
    "Maruko Gothic CJKjp Medium",
    "Noto Sans TC",
    "Source Han Sans TC",
    "Microsoft JhengHei",
    "sans-serif"
  ],
  "customColors": {
    "useAutoLuminance": true,
    "forceTextColor": "#ffffff",
    "forceShadowColor": "rgba(0,0,0,0.5)"
  },
  "layout": {
    "maxCharsPerLine": 9,
    "fontSizeRatio": 0.1,
    "paddingRatio": 0.07,
    "bold": false,
    "italic": false,
    "shadowEnable": true,
    "lineHeightRatio": 1.4,
    "shadowOffset": 4,
    "titleBgEnable": false,
    "titleBgColor": "#000000",
    "titleBgOpacity": 0.4,
    "titleBgOffsetYRatio": 0,
    "titleBgPaddingXRatio": 0.2,
    "titleBgPaddingYRatio": 0.1,
    "titleBgRadius": 10
  },
  "watermark": {
    "enable": false,
    "text": "",
    "fontSizeRatio": 0.012,
    "opacity": 0.15,
    "position": {
      "right": true,
      "bottomRatio": 0.9
    }
  }
}